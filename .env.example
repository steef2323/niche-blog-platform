# Copy to .env.local for local dev (never commit .env.local).
# For Mac mini autorelease, prefer: npx vercel env pull .env.local --environment production

AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Optional: emergency stop for bots/scripts (scripts check this)
PAPERCLIP_DEPLOY_FROZEN=0

# Optional: override production smoke-test URL
# PRODUCTION_URL=https://www.sipenpaints.nl
